# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Solana — used by /settle for on-chain USDC payments via Solana Pay.
# Defaults are devnet + public RPC; safe to leave blank for the demo.
# Switch SOLANA_CLUSTER to mainnet-beta only after live devnet testing.
SOLANA_CLUSTER=devnet
# Optional: override the public RPC (recommended for production — get a free tier from Helius/QuickNode).
SOLANA_RPC_URL=
# Optional: override the USDC mint. Defaults: devnet 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU,
# mainnet-beta EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v.
USDC_MINT=

# Database (SQLite for local development)
# Local: resolved relative to packages/database/prisma/, so the file lives at
# packages/database/prisma/dev.db. Used by Prisma at both build and runtime.
# Production (Railway): use an absolute path on a mounted volume, e.g.
#   DATABASE_URL=file:/data/splitstable.db
DATABASE_URL=file:./dev.db
