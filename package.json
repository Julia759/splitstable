{
  "name": "splitstable",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "bot:dev": "corepack pnpm --filter @splitstable/bot dev",
    "test": "corepack pnpm -r --if-present test",
    "typecheck": "tsc -b",
    "clean": "find apps packages -name dist -type d -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  }
}
