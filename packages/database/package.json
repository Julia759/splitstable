{
  "name": "@splitstable/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:reset": "node -e \"require('fs').rmSync('test.db',{force:true});require('fs').rmSync('test.db-journal',{force:true})\"",
    "test:migrate": "cross-env DATABASE_URL=file:./test.db prisma migrate deploy",
    "test:run": "cross-env DATABASE_URL=file:./test.db node --test test/*.test.mjs",
    "test": "corepack pnpm run build && corepack pnpm run test:reset && corepack pnpm run test:migrate && corepack pnpm run test:run",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@splitstable/solana": "workspace:*",
    "@splitstable/split-engine": "workspace:*"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3"
  }
}
